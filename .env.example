# =============================================================================
# FR2 — O que pode ir ao browser (NEXT_PUBLIC_*) vs servidor apenas
# =============================================================================
# Variáveis NEXT_PUBLIC_* são embutidas no bundle cliente — NUNCA coloque
# passwords, service_role, DATABASE_URL, READINESS_SECRET, BETTER_AUTH_SECRET
# ou tokens privados em NEXT_PUBLIC_*.
# =============================================================================

# --- Postgres (Drizzle + Better Auth) — servidor apenas ---
# Supabase: Dashboard → Project Settings → Database → Connection string → URI
# Modo Transaction (pooler), porta típica 6543, sslmode=require.
# O mesmo projeto Supabase deve alimentar DATABASE_URL e NEXT_PUBLIC_SUPABASE_URL (FR1).
DATABASE_URL=

# --- Supabase (público no browser — mesmo projeto que DATABASE_URL) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Better Auth (servidor; nunca expor ao cliente) ---
BETTER_AUTH_SECRET=dev-dev-dev-dev-dev-dev-dev-dev-12-3456-7890-abcd
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Readiness (servidor) — GET /api/health/ready ---
# Sem READINESS_SECRET definido, o endpoint de readiness responde 503 (desativado).
# Com segredo: enviar Authorization: Bearer <READINESS_SECRET>.
READINESS_SECRET=

# --- Upstash (opcional; rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_MEMBERS_SEARCH_PER_MINUTE=30

# --- Seed superadmin (scripts manuais / não produção) ---
SUPERADMIN_SEED_EMAIL=admin@example.com
