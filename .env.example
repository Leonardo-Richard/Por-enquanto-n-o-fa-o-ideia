# =============================================================================
# FR2 — O que pode ir ao browser (NEXT_PUBLIC_*) vs servidor apenas
# =============================================================================
# Variáveis NEXT_PUBLIC_* são embutidas no bundle cliente — NUNCA coloque
# passwords, service_role, DATABASE_URL, READINESS_SECRET, BETTER_AUTH_SECRET
# ou tokens privados em NEXT_PUBLIC_*.
# =============================================================================

# --- Postgres (Drizzle + Better Auth) — servidor apenas ---
# Supabase: Dashboard → Connect → copiar a URI do modo escolhido.
# Session pooler (recomendado em Windows / só IPv4): postgres.[REF] @ aws-0|aws-1-[REGIAO].pooler.supabase.com:5432
# O índice aws-0 vs aws-1 não se adivinha — copiar do Dashboard ou: npm run probe:pooler
# Transaction pooler (serverless / db com IPv6): postgres @ db.[REF].supabase.co:6543 — em muitos PCs Windows dá ENOTFOUND.
# O mesmo projeto Supabase deve alimentar DATABASE_URL e NEXT_PUBLIC_SUPABASE_URL (FR1).
DATABASE_URL=

# --- Supabase (público no browser — mesmo projeto que DATABASE_URL) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Better Auth (servidor; nunca expor ao cliente) ---
BETTER_AUTH_SECRET=dev-dev-dev-dev-dev-dev-dev-dev-12-3456-7890-abcd
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Readiness (servidor) — GET /api/health/ready ---
# Sem READINESS_SECRET definido, o endpoint de readiness responde 503 (desativado).
# Com segredo: enviar Authorization: Bearer <READINESS_SECRET>.
READINESS_SECRET=

# --- Upstash (opcional; rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_MEMBERS_SEARCH_PER_MINUTE=30

# --- Seed superadmin (scripts manuais / não produção) ---
SUPERADMIN_SEED_EMAIL=admin@example.com

# --- ADN (NFS-e / worker) — servidor apenas (NFR19) ---
# HMAC para rotas /api/internal/v1/adn/* (NFR20). Nunca expor ao browser.
ADN_WORKER_HMAC_SECRET=
# Storage: bucket privado + *service role* (assinatura PUT/GET no servidor).
SUPABASE_SERVICE_ROLE_KEY=
ADN_STORAGE_BUCKET=adn-artifacts
# TTL URL download (GET …/download) — default 90 s (60–120 conforme story).
ADN_DOWNLOAD_URL_TTL_SECONDS=90
# TTL URL upload worker (prepare) — default 900 s (≤ 15 min).
ADN_WORKER_UPLOAD_URL_TTL_SECONDS=900
# Limites em memória (MVP): pedidos POST …/adn/sync por utilizador+empresa / minuto; pedidos internos HMAC por IP / minuto.
ADN_PUBLIC_SYNC_RATE_LIMIT_PER_MIN=20
ADN_INTERNAL_RATE_PER_MIN=240
