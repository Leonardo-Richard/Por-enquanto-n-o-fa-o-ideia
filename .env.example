# =============================================================================
# FR2 — O que pode ir ao browser (NEXT_PUBLIC_*) vs servidor apenas
# =============================================================================
# Variáveis NEXT_PUBLIC_* são embutidas no bundle cliente — NUNCA coloque
# passwords, service_role, DATABASE_URL, READINESS_SECRET, BETTER_AUTH_SECRET
# ou tokens privados em NEXT_PUBLIC_*.
# =============================================================================

# --- Postgres (Drizzle + Better Auth) — servidor apenas ---
# Supabase: Dashboard → Connect → copiar a URI do modo escolhido.
# Session pooler (recomendado em Windows / só IPv4): postgres.[REF] @ aws-0|aws-1-[REGIAO].pooler.supabase.com:5432
# O índice aws-0 vs aws-1 não se adivinha — copiar do Dashboard ou: npm run probe:pooler
# Transaction pooler (serverless / db com IPv6): postgres @ db.[REF].supabase.co:6543 — em muitos PCs Windows dá ENOTFOUND.
# O mesmo projeto Supabase deve alimentar DATABASE_URL e NEXT_PUBLIC_SUPABASE_URL (FR1).
DATABASE_URL=
# Worker ADN (Docker / Easypanel): se DATABASE_URL não chegar ao contentor, duplique a URI aqui.
# ADN_WORKER_DATABASE_URL=

# --- Supabase (público no browser — mesmo projeto que DATABASE_URL) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Better Auth (servidor; nunca expor ao cliente) ---
BETTER_AUTH_SECRET=dev-dev-dev-dev-dev-dev-dev-dev-12-3456-7890-abcd
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Readiness (servidor) — GET /api/health/ready ---
# Sem READINESS_SECRET definido, o endpoint de readiness responde 503 (desativado).
# Com segredo: enviar Authorization: Bearer <READINESS_SECRET>.
READINESS_SECRET=

# --- Upstash (opcional; rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_MEMBERS_SEARCH_PER_MINUTE=30

# --- Seed superadmin (scripts manuais / não produção) ---
SUPERADMIN_SEED_EMAIL=admin@example.com

# --- Guia público de certificado ADN (browser — apenas URL; sem segredos, CE-NFR1) ---
# HTTPS placeholder; em produção aponte para o manual interno ou site aprovado.
NEXT_PUBLIC_ADN_CERT_RUNBOOK_URL=https://docs.example.com/adn/certificado

# --- ADN (NFS-e / worker) — servidor apenas (NFR19) ---
# HMAC para rotas /api/internal/v1/adn/* (NFR20). Nunca expor ao browser.
ADN_WORKER_HMAC_SECRET=
# Storage: bucket privado + *service role* (assinatura PUT/GET no servidor).
# Obrigatório para uploads ADN; o backend (:3001) faz merge de frontend/.env.local ao arrancar — pode ficar só no frontend.
SUPABASE_SERVICE_ROLE_KEY=
ADN_STORAGE_BUCKET=adn-artifacts
# TTL URL download (GET …/download) — default 90 s (60–120 conforme story).
ADN_DOWNLOAD_URL_TTL_SECONDS=90
# TTL URL upload worker (prepare) — default 900 s (≤ 15 min).
ADN_WORKER_UPLOAD_URL_TTL_SECONDS=900
# Limites em memória (MVP): pedidos POST …/adn/sync por utilizador+empresa / minuto; pedidos internos HMAC por IP / minuto.
ADN_PUBLIC_SYNC_RATE_LIMIT_PER_MIN=20
ADN_INTERNAL_RATE_PER_MIN=240
# Verificação on-demand do certificado (UIP-02) — limite POST …/certificate-readiness/verify por utilizador+empresa / minuto.
ADN_CERT_VERIFY_RATE_LIMIT_PER_MIN=10
# *Probe* portal → worker (UIP-03). Com `ADN_CERT_PROBE_ENABLED=false`, não chama o worker mesmo com URL.
# O *probe* só corre quando **ambos** existem: `ADN_WORKER_INTERNAL_BASE_URL` e `ADN_WORKER_HMAC_SECRET` (NFR20; não basta URL sem segredo).
ADN_CERT_PROBE_ENABLED=false
ADN_WORKER_INTERNAL_BASE_URL=
# Caminho no worker (HMAC igual ao interno ADN). Ex.: /internal/v1/adn/certificate-probe
ADN_CERT_PROBE_PATH=/internal/v1/adn/certificate-probe
ADN_CERT_PROBE_TIMEOUT_MS=8000

# --- Worker NFSE_dist (workers/nfse-portal-bridge) — URL do Next acessível a partir da VM Windows ---
# Ex.: http://localhost:3000 ou https://portal.seudominio.internal
PORTAL_INTERNAL_URL=
# URL do backend dedicado (backend). Se vazio, worker usa PORTAL_INTERNAL_URL.
API_INTERNAL_URL=
# Jobs ADN presos em «running» (worker morto, 503, etc.): ao iniciar o worker, marcar como failed se started_at for mais antigo que N horas. 0=desactivar.
ADN_CLEAN_STALE_ON_WORKER_START=1
# Limiar (horas) para órfãos — também usado por `npm run fix:adn-stale-jobs`. Recolhas muito longas: aumente ou desactive o arranque.
ADN_STALE_JOB_HOURS=24
# Espelho XML/PDF na pasta raiz do worker: opt-in. Sem NFSE_LOCAL_MIRROR_ENABLED=1, ficheiros só no portal (download pelo browser); coleta mensal igual.
# NFSE_LOCAL_MIRROR_ENABLED=1
# NFSE_LOCAL_MIRROR_DISABLED=1

# --- Frontend -> backend dedicado (cutover gradual) ---
# Quando definido, o web app reescreve /api/* para esta URL.
# Ex.: http://localhost:3001
API_BASE_URL=

# --- Upload de certificado ADN (browser → cofre) — ver docs/adr/0001-upload-certificado-browser-para-cofre.md ---
# API: só activa com valor exacto "true" (defesa em profundidade). Sem isto, GET/POST/DELETE …/certificate → 404.
CERT_UPLOAD_API_ENABLED=false
# UI: omitir ou "true" = formulário visível; "false" = ocultar envio no card ADN (apenas booleano público).
NEXT_PUBLIC_CERT_UPLOAD_UI_ENABLED=true
# Tamanho máximo do ficheiro (bytes). Default 5 MB.
CERT_UPLOAD_MAX_BYTES=5242880
# Texto de ajuda no cliente (MB); alinhar com CERT_UPLOAD_MAX_BYTES em produção.
NEXT_PUBLIC_CERT_UPLOAD_MAX_MB=5
# Limite de POST por utilizador+empresa (janela em minutos; defaults: 5 uploads / 15 min).
CERT_UPLOAD_RATE_MAX_PER_WINDOW=5
CERT_UPLOAD_RATE_WINDOW_MIN=15
# Driver do cofre: "supabase-storage" (real) ou "mock" (somente testes).
CERT_UPLOAD_VAULT_DRIVER=supabase-storage
# Bucket privado para os PKCS#12 por empresa.
CERT_UPLOAD_VAULT_BUCKET=adn-certificates
