# PostgreSQL (Drizzle + Better Auth)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/portal_nf

# Better Auth (mín. 32 caracteres em produção)
BETTER_AUTH_SECRET=dev-dev-dev-dev-dev-dev-dev-dev-12-3456-7890-abcd
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upstash (rate limiting — opcional; sem isto o limite fica desativado excepto NODE_ENV=test)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_MEMBERS_SEARCH_PER_MINUTE=30

# Seed superadmin (apenas scripts manuais / não produção)
SUPERADMIN_SEED_EMAIL=admin@example.com

# Playwright — smoke LER-08 (registo → nova empresa → utilizadores). Em CI o job define isto.
# PLAYWRIGHT_LER_SMOKE=1
