{
  "name": "portal-automacao-nf",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "probe:pooler": "npm run probe:pooler -w frontend",
    "vendor:nfse-dist": "node scripts/vendor-nfse-dist.mjs",
    "setup:adn-playwright": "node scripts/setup-adn-playwright.mjs",
    "sync:adn-extension-from-chrome": "node scripts/sync-adn-extension-from-chrome.mjs",
    "adn:enqueue-real-company": "python scripts/enqueue_adn_real_company_job.py",
    "force:adn-bridge": "node scripts/run-adn-bridge-force-once.mjs",
    "smoke:adn-bridge": "node scripts/run-adn-bridge-smoke-once.mjs",
    "worker:adn-bridge": "node scripts/run-adn-bridge-watch.mjs",
    "fix:adn-stale-jobs": "node scripts/release-stale-adn-jobs.mjs",
    "fix:adn-all-running": "node scripts/fix-adn-all-running-now.mjs",
    "status:adn-jobs": "node scripts/adn-jobs-status.mjs",
    "dev:with-adn-bridge": "concurrently -k -n \"portal,adn\" -c \"cyan,magenta\" \"npm run dev:frontend\" \"npm run worker:adn-bridge\"",
    "dev:with-adn-bridge-backend": "concurrently -k -n \"portal,adn\" -c \"cyan,magenta\" \"npm run dev:backend\" \"npm run worker:adn-bridge\"",
    "dev:auto": "npm run dev:auto -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "is-regex": "^1.2.1",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "is-regex": "^1.2.1"
  }
}
